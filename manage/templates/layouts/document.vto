  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" value="light">
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/assets/global.css">
</head>
<body>

{{ content}}

<script type="module" src="/assets/global.js"></script>

</body>
</html>
