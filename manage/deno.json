{
  "name": "@stewpot/manage",
  "version": "0.0.0",
  "license": "MIT",
  "exports": "./main.ts",
  "publish": {
    "exclude": ["*_test.ts"]
  },
  "tasks": {
    "dev": "deno -RWN --watch=templates/,static/ main.ts",
    "serve": "deno serve -RW serve.ts",
    "bundle": "deno -RW bundle.ts",
    "doc:lint": "deno doc --lint main.ts && deno check --doc main.ts"
  },
  "imports": {
    "@std/front-matter": "jsr:@std/front-matter@^1.0.9",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/ulid": "jsr:@std/ulid@^1.0.0",
    "@std/assert": "jsr:@std/assert@1",
    "@std/http": "jsr:@std/http@1",
    "ventojs": "npm:ventojs@^2.3.1"
  }
}
